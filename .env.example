# ==========================================
# APP A: Authentication App
# ==========================================
# Client ID and Secret for Facebook Login
FACEBOOK_CLIENT_ID="your_auth_app_client_id"
FACEBOOK_CLIENT_SECRET="your_auth_app_client_secret"

# NextAuth base configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="super_secret_key_change_me"

# ==========================================
# APP B: Messenger Platform
# ==========================================
# Access Token for the Page (generate in App B -> Messenger settings)
PAGE_ACCESS_TOKEN="your_page_access_token"

# Verify token for webhook verification (can be any string you choose when setting up the webhook)
VERIFY_TOKEN="my_custom_verify_token_123"

# The username of your Facebook Page (e.g. MyStoreTH) for the m.me link
NEXT_PUBLIC_PAGE_NAME="your_page_username_or_id"
